# Anthropic API key for AI enrichment and menu builder
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Email via Resend (https://resend.com — free 100/day)
# Without this, confirmation codes are logged to console only
# RESEND_API_KEY=re_your-key-here
# MAZARINE_FROM_EMAIL=Mazarine <onboarding@resend.dev>

# Admin notification email — receives alerts when users register/verify
# MAZARINE_ADMIN_EMAIL=dagbert@outlook.com

# Database path (default: mazarine.db locally, /data/mazarine.db in Docker)
# MAZARINE_DB_PATH=/data/mazarine.db

# Upload directory (default: uploads locally, /data/uploads in Docker)
# MAZARINE_UPLOAD_DIR=/data/uploads

# Server port (default: 8000, Railway sets this automatically)
# PORT=8000
